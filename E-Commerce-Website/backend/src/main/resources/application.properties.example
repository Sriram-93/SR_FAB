# Server Configuration
server.port=8080
server.tomcat.max-http-form-post-size=20MB
server.tomcat.max-swallow-size=20MB
spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=20MB

# Database Configuration (Use Aiven MySQL or Local)
# Local: jdbc:mysql://localhost:3306/srfab
# Aiven: jdbc:mysql://HOST:PORT/DATABASE?sslMode=REQUIRED&allowPublicKeyRetrieval=true&useSSL=true
spring.datasource.url=jdbc:mysql://localhost:3306/srfab
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.maximum-pool-size=5

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=false

# JWT Configuration
jwt.secret=YOUR_JWT_SECRET_KEY_HEX_OR_BASE64
jwt.expiration=86400000

# Email Configuration (Gmail SMTP)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=srfabrics001@gmail.com
spring.mail.password=YOUR_GMAIL_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.debug=false
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000
app.admin.email=srfabrics001@gmail.com

# Cloudinary Configuration (Image CDN)
cloudinary.cloud-name=YOUR_CLOUDINARY_CLOUD_NAME
cloudinary.api-key=YOUR_CLOUDINARY_API_KEY
cloudinary.api-secret=YOUR_CLOUDINARY_API_SECRET

# Stock Alert Threshold
app.stock.alert-threshold=5

# AI 3D Model Generation
ai.3d.provider=hf
# Option 1: Hugging Face (Free)
ai.hf.api-token=YOUR_HF_API_TOKEN
ai.hf.model-id=stabilityai/stable-fast-3d
ai.hf.inference-base-url=https://router.huggingface.co/hf-inference/models
ai.hf.request-timeout-ms=180000
ai.hf.max-retries=2

# Option 2: Tripo (Premium, larger models)
ai.tripo.api-key=YOUR_TRIPO_API_KEY
ai.model.output-format=glb
ai.model.cloudinary-folder=products/3d-models
ai.model.poll-interval-ms=4500
ai.model.max-poll-attempts=30

# Virtual Try-On (RapidAPI)
replicate.api-token=YOUR_REPLICATE_API_TOKEN
rapidapi.key=YOUR_RAPIDAPI_KEY
rapidapi.host=try-on-diffusion.p.rapidapi.com
